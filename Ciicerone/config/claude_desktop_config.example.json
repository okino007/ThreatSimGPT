{
  "mcpServers": {
    "ciicerone-vm": {
      "command": "python",
      "args": [
        "-m",
        "ciicerone.mcp.server"
      ],
      "env": {
        "PROXMOX_HOST": "192.168.1.100",
        "PROXMOX_PORT": "8006",
        "PROXMOX_USER": "ciicerone@pve",
        "PROXMOX_TOKEN_NAME": "automation",
        "PROXMOX_TOKEN_VALUE": "YOUR_SECRET_TOKEN_HERE",
        "PROXMOX_NODE": "pve"
      }
    }
  }
}
